{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es6",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist", // Just output directly to a 'dist' folder
    "strict": true
  },
  "lib": ["es2015"],
  "include": [
    "src/**/*" // Compile everything inside the src folder
  ]
}
